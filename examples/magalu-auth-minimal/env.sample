# Copia para `.env` na mesma pasta (o ficheiro `.env` está no .gitignore do monorepo).
# Client ID do app (portal Magalu / Loja de APPs). Nunca coloques o Client Secret aqui.
VITE_MAGALU_CLIENT_ID=

# Origens aceites para postMessage (CSV). Inclui o host deste exemplo e o Geraldo em produção.
VITE_POSTMESSAGE_ORIGINS=https://geraldo-restaurantes.aiqfome.com,http://localhost:5175
